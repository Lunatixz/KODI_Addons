msgctxt "Addon Summary"
msgid "Browse PlayOn from Kodi."
msgstr "Bläddra i PlayOn från Kodi."

msgctxt "Addon Description"
msgid "PlayOn is a streaming media brand and software suite that enables users to view and record videos from numerous online content providers."
msgstr "PlayOn är ett varumärke för strömmande media och en programvarusvit som gör det möjligt för användare att visa och spela in videor från ett stort antal leverantörer av onlineinnehåll."

msgctxt "Addon Disclaimer"
msgid "Requires Playon Server Software"
msgstr "Kräver serverprogramvaran för PlayOn"

msgctxt "#30000"
msgid "Enable Debugging [Log errors]"
msgstr "Aktivera felsökning [logga fel]"

msgctxt "#30001"
msgid "Navigate to m.playon.tv in a browser to get the resolved IP."
msgstr "Navigera till m.playon.tv i en webbläsare för att slå upp IP."

msgctxt "#30002"
msgid "Playon IP:Port"
msgstr "Playon IP:Port"

msgctxt "#30003"
msgid "Preferred Playback Method"
msgstr "Föredragen uppspelningsmetod"

msgctxt "#30004"
msgid "UPNP Server"
msgstr "UPNP-server"

msgctxt "#30005"
msgid ""
msgstr ""

msgctxt "#30010"
msgid "Something went wrong, Try again..."
msgstr "Någonting gick fel. Försök igen..."

msgctxt "#30011"
msgid "Connect to PlayOn: %s"
msgstr "Anslut till PlayOn: %s"

msgctxt "#30012"
msgid "Please Check Playon Server and IP:Port settings."
msgstr "Kontrollera Playon-servern och inställningar för IP:port."

msgctxt "#30013"
msgid "Found Playon UPNP Server"
msgstr "Hittade Playon UPNP-server"

msgctxt "#30014"
msgid "Navigate to UPNP, locate Playon Server"
msgstr "Navigera till UPNP, hitta Playon-servern"

msgctxt "#30015"
msgid "Kodi UPNP Enabled"
msgstr "Kodi UPNP aktiverat"

msgctxt "#30016"
msgid "Enter Search Term"
msgstr "Ange sökvillkor"

msgctxt "#30017"
