msgid "[B]Downloading:[/B]"
msgstr "[B]Hämtar ner:[/B]"

msgctxt "#30024"
msgid " | [B]Speed:[/B]"
msgstr " | [B]Hastighet:[/B]"

msgctxt "#30025"
msgid " | [B]ETA:[/B]"
msgstr " | [B]Klar om:[/B]"

msgctxt "#30026"
msgid ""
"Permission Required\n"
"Kodi needs full storage access to install this APK.\n"
"Please select 'Permissions' -> 'Files and Media' -> 'Allow all the time' on the next screen."
