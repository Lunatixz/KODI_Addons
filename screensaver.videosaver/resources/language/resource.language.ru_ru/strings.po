msgctxt "Addon Summary"
msgid "Create a screensaver from any Kodi video source."
msgstr "Создать хранитель экрана из любого источника видео Kodi."

msgctxt "Addon Description"
msgid "Dynamic screensaver using Local content, SmartPlaylists, Plugins and UPNP Servers."
msgstr "Динамический хранитель экрана с использованием локальных материалов, умных плейлистов, плагинов и UPNP-серверов."

msgctxt "Addon Disclaimer"
msgid "Streaming sources not recommend for metered Internet."
msgstr "Потоковые источники не рекомендуются для тарифицируемого Интернета."

msgctxt "#32001"
msgid "Something went wrong, Try again later ..."
msgstr "Что-то пошло не так, Повторите попытку позже ..."

msgctxt "#32002"
msgid "Video Type"
msgstr "Тип видео"

msgctxt "#32003"
