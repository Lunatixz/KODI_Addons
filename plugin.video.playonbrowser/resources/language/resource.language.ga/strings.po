msgctxt "Addon Summary"
msgid "Browse PlayOn from Kodi."
msgstr "Brabhsáil PlayOn ó Kodi."

msgctxt "Addon Description"
msgid "PlayOn is a streaming media brand and software suite that enables users to view and record videos from numerous online content providers."
msgstr "Is branda meán sruthú agus sraith bogearraí é PlayOn a chuireann ar chumas úsáideoirí físeáin a fheiceáil agus a thaifeadadh ó go leor soláthraithe ábhair ar líne."

msgctxt "Addon Disclaimer"
msgid "Requires Playon Server Software"
msgstr "Éilíonn Bogearraí Freastalaí Playon"

msgctxt "#30000"
msgid "Enable Debugging [Log errors]"
msgstr "Cumasaigh Dífhabhtú [Earráidí Logála]"

msgctxt "#30001"
msgid "Navigate to m.playon.tv in a browser to get the resolved IP."
msgstr "Téigh chuig m.playon.tv i mbrabhsálaí chun an seoladh IP réitithe a fháil."

msgctxt "#30002"
msgid "Playon IP:Port"
msgstr "Playon IP:Port"

msgctxt "#30003"
msgid "Preferred Playback Method"
msgstr "Modh Athsheinm is Fearr"

msgctxt "#30004"
msgid "UPNP Server"
msgstr "Freastalaí UPNP"

msgctxt "#30005"
msgid ""
msgstr " "

msgctxt "#30010"
msgid "Something went wrong, Try again..."
msgstr "Chuaigh rud éigin mícheart, déan iarracht arís..."

msgctxt "#30011"
msgid "Connect to PlayOn: %s"
msgstr "Ceangail le PlayOn: %s"

msgctxt "#30012"
msgid "Please Check Playon Server and IP:Port settings."
msgstr "Seiceáil socruithe Freastalaí Playon agus IP:Port le do thoil."

msgctxt "#30013"
msgid "Found Playon UPNP Server"
msgstr "Aimsíodh Freastalaí UPNP Playon"

msgctxt "#30014"
msgid "Navigate to UPNP, locate Playon Server"
msgstr "Téigh go UPNP, aimsigh Freastalaí Playon"

msgctxt "#30015"
msgid "Kodi UPNP Enabled"
msgstr "Cumasaithe UPNP Kodi"

msgctxt "#30016"
msgid "Enter Search Term"
msgstr "Cuir isteach Téarma Cuardaigh"

msgctxt "#30017"
msgid "Add to PlayLater"
msgstr "Cuir le Seinn Níos Déanaí"

msgctxt "#30018"
msgid "General"
msgstr "Ginearálta"
