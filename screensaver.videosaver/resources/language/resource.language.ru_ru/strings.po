msgstr "Несколько видео"

msgctxt "#32011"
msgid "Set ScreenSaver Volume [Restored to Previous Level on Stop]"
msgstr "Установить громкость хранителя экрана [Восстанавливается до предыдущего уровня при остановке]"

msgctxt "#32012"
msgid "Enable Debugging [Log errors]"
msgstr "Включить отладку [Записывать ошибки в журнал]"

