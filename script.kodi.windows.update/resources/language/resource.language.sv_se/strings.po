msgctxt "Addon Summary"
msgid "Download and Install Kodi packages."
msgstr "Hämta och installera Kodi-paket."

msgctxt "Addon Description"
msgid "Download and Install Kodi window executables; select from  Nightlies, Releases, Snapshots and Test-builds."
msgstr "Hämta och installera körbara Kodi-filer för Windows; välj från  Nightlies, Releases, Snapshots och Test-byggen."

msgctxt "Addon Disclaimer"
msgid "UWP not supported! Not intended for Kodi installation through the Windows Store."
msgstr "UWP stöds inte! Inte tänkt för Kodi-installation genom Windows Store."

msgctxt "#30000"
msgid "Enable Debugging [Log errors]"
msgstr "Aktivera felsökning [Logga fel]"

msgctxt "#30001"
msgid "Something went wrong, Try again later..."
msgstr "Någonting gick fel. Försök igen senare..."

msgctxt "#30002"
msgid "Downloading..."
msgstr "Hämtar..."

msgctxt "#30003"
msgid "Keep all downloads?"
msgstr "Behålla alla hämtade filer?"

msgctxt "#30004"
msgid "File already exists"
msgstr "Filen finns redan"

msgctxt "#30005"
msgid "Install"
msgstr "Installera"

msgctxt "#30006"
msgid "Redownload"
msgstr "Hämta ner igen"

msgctxt "#30007"
msgid "Installation Complete, File Removed"
msgstr "Installationen är färdig, filen borttagen"

msgctxt "#30008"
msgid "Cleanup download after installation"
msgstr "Städa upp hämtning efter installation"

msgctxt "#30009"
msgid "UWP Installations Not Supported!"
msgstr "UWP-installationer stöds inte!"

msgctxt "#30010"
msgid "/../../Users/*/AppData/Local/Packages/XBMCFoundation.Kodi_*"
msgstr "/../../Users/*/AppData/Local/Packages/XBMCFoundation.Kodi_*"

msgctxt "#30011"
msgid "Plugin disabled"
msgstr "Tillägget inaktiverat"

msgctxt "#30012"
msgid "Would you like to disable this plugin?"
msgstr "Vill du inaktivera detta tillägg?"

msgctxt "#30014"
msgid "Current Windows Platform (%s)"
msgstr "Aktuell Windows-plattform (%s)"

msgctxt "#30015"
msgid "Semi-stable (Monthly builds)."
msgstr "Halvstabila (månatliga byggen)."

msgctxt "#30016"
msgid "Stable (Final releases)."
msgstr "Stabila (slutgiltiga utgåvor)."

msgctxt "#30017"
msgid "Unstable (Daily builds)."
msgstr "Ostabila (dagliga byggen)."

msgctxt "#30018"
msgid "Experimental (Debugging builds)."
msgstr "Experimentella (felsökningsbyggen)."

msgctxt "#30019"
msgid "Incompatible platform"
msgstr "Inkompatibel plattform"

msgctxt "#30020"
msgid "Enable Silent Installation"
msgstr "Aktivera tyst installation"

msgctxt "#30021"
msgid "Current Kodi Branch (%s.%s-%s)"
msgstr "Aktuell Kodi-gren (%s.%s-%s)"

msgctxt "#30023"
msgid "[B]Downloading:[/B]"
msgstr "[B]Hämtar ner:[/B]"

msgctxt "#30024"
msgid " | [B]Speed:[/B]"
msgstr " | [B]Hastighet:[/B]"

msgctxt "#30025"
msgid " | [B]ETA:[/B]"
msgstr " | [B]Klar om:[/B]"
