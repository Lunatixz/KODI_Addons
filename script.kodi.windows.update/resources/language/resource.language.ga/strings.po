msgctxt "Addon Summary"
msgid "Download and Install Kodi packages."
msgstr "Íoslódáil agus Suiteáil pacáistí Kodi."

msgctxt "Addon Description"
msgid "Download and Install Kodi window executables; select from  Nightlies, Releases, Snapshots and Test-builds."
msgstr "Íoslódáil agus Suiteáil comhaid inrite fuinneoige Kodi; roghnaigh ó  Nightlies, Releases, Snapshots agus Test-builds."

msgctxt "Addon Disclaimer"
msgid "UWP not supported! Not intended for Kodi installation through the Windows Store."
msgstr "Ní thacaítear le UWP! Níl sé beartaithe é a shuiteáil le haghaidh Kodi tríd an Windows Store."

msgctxt "#30000"
msgid "Enable Debugging [Log errors]"
msgstr "Cumasaigh Dífhabhtú [Earráidí Logála]"

msgctxt "#30001"
msgid "Something went wrong, Try again later..."
msgstr "Chuaigh rud éigin mícheart, déan iarracht arís ar ball..."

msgctxt "#30002"
msgid "Downloading..."
msgstr "Ag íoslódáil..."

msgctxt "#30003"
msgid "Keep all downloads?"
msgstr "Coinnigh gach íoslódáil?"

msgctxt "#30004"
msgid "File already exists"
msgstr "Tá an comhad ann cheana féin"

msgctxt "#30005"
msgid "Install"
msgstr "Suiteáil"

msgctxt "#30006"
msgid "Redownload"
msgstr "Ath-íoslódáil"

msgctxt "#30007"
msgid "Installation Complete, File Removed"
msgstr "Suiteáil Críochnaithe, Comhad Bainte"

msgctxt "#30008"
msgid "Cleanup download after installation"
msgstr "Íoslódáil glanadh tar éis a shuiteáil"

msgctxt "#30009"
msgid "UWP Installations Not Supported!"
msgstr "Ní thacaítear le suiteálacha UWP!"

msgctxt "#30010"
msgid "/../../Users/*/AppData/Local/Packages/XBMCFoundation.Kodi_*"
msgstr "/../../Úsáideoirí/*/AppData/Local/Pacáistí/XBMCFoundation.Kodi_*"

msgctxt "#30011"
msgid "Plugin disabled"
msgstr "Breiseán díchumasaithe"

msgctxt "#30012"
msgid "Would you like to disable this plugin?"
msgstr "Ar mhaith leat an breiseán seo a dhíchumasú?"

msgctxt "#30014"
msgid "Current Windows Platform (%s)"
msgstr "Ardán Reatha Windows (%s)"

msgctxt "#30015"
msgid "Semi-stable (Monthly builds)."
msgstr "Leathchobhsaí (Tógálacha míosúla)."

msgctxt "#30016"
msgid "Stable (Final releases)."
msgstr "Cobhsaí (Eisiúintí deiridh)."

msgctxt "#30017"
msgid "Unstable (Daily builds)."
msgstr "Éagobhsaí (Tógálacha laethúla)."

msgctxt "#30018"
msgid "Experimental (Debugging builds)."
msgstr "Turgnamhach (Tógálacha dífhabhtaithe)."

msgctxt "#30019"
msgid "Incompatible platform"
msgstr "Ardán neamh-chomhoiriúnach"

msgctxt "#30020"
msgid "Enable Silent Installation"
msgstr "Cumasaigh Suiteáil Chiúin"

msgctxt "#30021"
msgid "Current Kodi Branch (%s.%s-%s)"
msgstr "Brainse reatha Kodi (%s.%s-%s)"

msgctxt "#30023"
msgid "[B]Downloading:[/B]"
msgstr "[B]Ag íoslódáil:[/B]"

msgctxt "#30024"
msgid " | [B]Speed:[/B]"
msgstr " | [B]Luas:[/B]"

msgctxt "#30025"
msgid " | [B]ETA:[/B]"
msgstr " | [B]EAST:[/B]"
