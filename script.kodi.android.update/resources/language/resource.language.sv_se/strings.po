msgstr "Vill du inaktivera detta tillägg?"

msgctxt "#30013"
msgid "Detecting Android version..."
msgstr "Identifierar Android-version..."

msgctxt "#30014"
msgid "Current Android platform (%s)"
msgstr "Aktuell Android-plattform (%s)"

msgctxt "#30015"
msgid "Semi-stable (Monthly builds)."
msgstr "Halvstabila (månatliga byggen)."

msgctxt "#30016"
msgid "Stable (Final releases)."
msgstr "Stabila (slutgiltiga utgåvor)."

msgctxt "#30017"
msgid "Unstable (Daily builds)."
msgstr "Ostabila (dagliga byggen)."

msgctxt "#30018"
msgid "Experimental (Debugging builds)."
msgstr "Experimentella (felsökningsbyggen)."

msgctxt "#30019"
msgid "Incompatible platform"
